---
import Layout from '../components/layout/Layout.astro';

const contacts = [
  {
    label: 'e-posta',
    value: 'sametakin44@gmail.com',
    href: 'mailto:sametakin44@gmail.com',
  },
  {
    label: 'linkedin',
    value: 'linkedin.com/in/sametakin44',
    href: 'https://linkedin.com/in/sametakin44',
  },
  {
    label: 'youtube',
    value: '@sametakin44',
    href: 'https://youtube.com/@sametakin44',
  },
  {
    label: 'github',
    value: 'github.com/sametakin',
    href: 'https://github.com/sametakin',
  },
  {
    label: 'konum',
    value: 'kavacık, beykoz · istanbul',
    href: null,
  },
];
---

<Layout
  title="iletişim — samet akın"
  description="samet akın ile iletişime geç"
>
  <section class="mx-auto max-w-[1200px] px-5 py-24">
    <h1 class="text-4xl font-bold tracking-tight">iletişim</h1>
    <p class="text-ink-400 mt-4 max-w-lg leading-relaxed">
      birlikte çalışmak, bir ml fikrini konuşmak ya da sadece kuş gözlemi
      rotası paylaşmak istersen, yazmaktan çekinme.
    </p>

    <div class="mt-12 divide-y divide-ink-800 max-w-2xl">
      {contacts.map((c) => {
        const Tag = c.href ? 'a' : 'div';
        return (
          <Tag
            href={c.href ?? undefined}
            target={c.href?.startsWith('http') ? '_blank' : undefined}
            rel={c.href?.startsWith('http') ? 'noopener noreferrer' : undefined}
            class:list={[
              'group flex items-center justify-between py-5 px-2 -mx-2 rounded-lg transition-all duration-200',
              c.href && 'hover:bg-ink-900/50 cursor-pointer',
            ]}
          >
            <div>
              <span class="text-xs font-mono text-ink-400 block">{c.label}</span>
              <span class="text-ink-100 mt-0.5 block">{c.value}</span>
            </div>
            {c.href && (
              <span class="text-ink-400 group-hover:text-accent group-hover:translate-x-1 transition-all duration-200">
                →
              </span>
            )}
          </Tag>
        );
      })}
    </div>
  </section>
</Layout>
