---
import Layout from '../components/layout/Layout.astro';
import YouTubeThumbnail from '../components/ui/YouTubeThumbnail';
import { tutorialPlaylists } from '../data/playlists';
import { getPlaylistData, getChannelVideos } from '../lib/youtube';

const playlists = tutorialPlaylists.map((meta) => ({
  meta,
  data: getPlaylistData(meta.id),
}));

const channelVideos = getChannelVideos();

// "jun 2026" gibi kısa, lowercase tarih.
const shortDate = (published: string) =>
  new Date(published)
    .toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
    .toLowerCase();
---

<Layout
  title="Videos — Samet Akın"
  description="Turkish tutorial playlists on deep learning and large language models."
>
  <section class="mx-auto max-w-5xl px-5 py-16 md:py-20">
    <header class="mb-12">
      <p class="text-xs font-mono text-ink-tertiary uppercase tracking-wider mb-2">
        videos
      </p>
      <h1 class="text-3xl md:text-4xl font-semibold text-ink-primary">
        tutorial playlists
      </h1>
      <p class="text-sm text-ink-secondary mt-3 max-w-md">
        Turkish-language video series on deep learning and LLMs.
      </p>
    </header>

    {playlists.map(({ meta, data }) => {
      if (!data) return null;
      return (
        <section class="mb-16">
          <div class="flex items-baseline justify-between mb-6">
            <h2 class="text-xl md:text-2xl font-medium text-ink-primary">
              {meta.title}
            </h2>
            <a
              href={data.playlistUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-mono text-ink-tertiary hover:text-accent"
            >
              playlist →
            </a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {data.videos.map((video) => (
              <a
                href={video.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <div class="aspect-video rounded-lg overflow-hidden bg-bg-elevated mb-3 isolate">
                  <YouTubeThumbnail
                    videoId={video.id}
                    title={video.title}
                    className="group-hover:scale-[1.02] transition duration-500"
                    client:visible
                  />
                </div>
                <h3 class="text-sm font-medium text-ink-primary group-hover:text-accent transition leading-snug line-clamp-2">
                  {video.title}
                </h3>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    {channelVideos.length > 0 && (
      <section class="mb-16">
        <div class="mb-6">
          <h2 class="text-xl md:text-2xl font-medium text-ink-primary">
            all videos
          </h2>
          <p class="text-sm text-ink-secondary mt-2">
            everything on the channel, newest first
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {channelVideos.map((video) => (
            <a
              href={video.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group block"
            >
              <div class="aspect-video rounded-lg overflow-hidden bg-bg-elevated mb-3 isolate">
                <YouTubeThumbnail
                  videoId={video.id}
                  title={video.title}
                  className="group-hover:scale-[1.02] transition duration-500"
                  client:visible
                />
              </div>
              <h3 class="text-sm font-medium text-ink-primary group-hover:text-accent transition leading-snug line-clamp-2">
                {video.title}
              </h3>
              <p class="text-xs font-mono text-ink-tertiary mt-1.5">
                {shortDate(video.published)}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>
</Layout>
