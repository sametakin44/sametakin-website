---
import Layout from '../components/layout/Layout.astro';
import YouTubeThumbnail from '../components/ui/YouTubeThumbnail';
import { tutorialPlaylists } from '../data/playlists';
import { getPlaylistData, getChannelVideos } from '../lib/youtube';

const playlists = tutorialPlaylists.map((meta) => ({
  meta,
  data: getPlaylistData(meta.id),
}));

const channelVideos = getChannelVideos();

// "jun 2026" gibi kısa, lowercase tarih.
const shortDate = (published: string) =>
  new Date(published)
    .toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
    .toLowerCase();
---

<Layout
  title="Videos — Samet Akın"
  description="Turkish tutorial playlists on deep learning and large language models."
>
  <section class="mx-auto max-w-5xl px-5 py-16 md:py-20">
    <header class="mb-14">
      <p class="eyebrow mb-3">Videos</p>
      <h1 class="font-display text-3xl md:text-5xl text-ink-primary">
        Tutorial playlists
      </h1>
      <p class="text-[15px] text-ink-secondary mt-4 max-w-md leading-[1.7]">
        Turkish-language video series on deep learning and LLMs.
      </p>
    </header>

    {playlists.map(({ meta, data }) => {
      if (!data) return null;
      return (
        <section class="mb-20 pt-8 border-t border-line-hair">
          <div class="flex items-baseline justify-between mb-8">
            <h2 class="font-display text-2xl md:text-3xl text-ink-primary">
              {meta.title}
            </h2>
            <a
              href={data.playlistUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-[11px] uppercase tracking-[0.25em] text-ink-tertiary hover:text-accent transition-colors duration-300"
            >
              Playlist →
            </a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {data.videos.map((video) => (
              <a
                href={video.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <div class="aspect-video rounded-[2px] overflow-hidden bg-bg-elevated mb-3 isolate">
                  <YouTubeThumbnail
                    videoId={video.id}
                    title={video.title}
                    className="group-hover:scale-[1.02] transition-transform duration-700 ease-out"
                    client:visible
                  />
                </div>
                <h3 class="font-sans text-sm font-medium text-ink-primary group-hover:text-accent transition-colors duration-300 leading-snug line-clamp-2">
                  {video.title}
                </h3>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    {channelVideos.length > 0 && (
      <section class="mb-16 pt-8 border-t border-line-hair">
        <div class="mb-8">
          <h2 class="font-display text-2xl md:text-3xl text-ink-primary">
            All videos
          </h2>
          <p class="text-sm text-ink-secondary mt-2">
            everything on the channel, newest first
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {channelVideos.map((video) => (
            <a
              href={video.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group block"
            >
              <div class="aspect-video rounded-[2px] overflow-hidden bg-bg-elevated mb-3 isolate">
                <YouTubeThumbnail
                  videoId={video.id}
                  title={video.title}
                  className="group-hover:scale-[1.02] transition-transform duration-700 ease-out"
                  client:visible
                />
              </div>
              <h3 class="font-sans text-sm font-medium text-ink-primary group-hover:text-accent transition-colors duration-300 leading-snug line-clamp-2">
                {video.title}
              </h3>
              <p class="text-xs font-mono text-ink-tertiary mt-1.5">
                {shortDate(video.published)}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>
</Layout>
