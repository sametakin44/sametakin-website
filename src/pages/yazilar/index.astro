---
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('tr-TR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}
---

<Layout
  title="yazılar — samet akın"
  description="samet akın'ın teknik yazıları: rag, llm, agentic ai"
>
  <section class="mx-auto max-w-[1200px] px-5 py-24">
    <h1 class="text-4xl font-bold tracking-tight text-ink-primary">yazılar</h1>
    <p class="text-ink-secondary mt-2 text-sm">teknik notlar, deneyler, öğrendiklerim</p>

    <div id="taslak" class="mt-12">
      {posts.length > 0 ? (
        <div class="divide-y divide-line-sub">
          {posts.map((post) => (
            <a
              href={`/yazilar/${post.id}`}
              class="group block py-5 hover:bg-bg-surface/60 -mx-4 px-4 rounded-lg transition-colors duration-200"
            >
              <div class="flex items-center gap-3">
                <h2 class="text-ink-primary font-medium group-hover:text-accent transition-colors duration-200">
                  {post.data.title}
                </h2>
                {post.data.draft && (
                  <span class="text-[10px] font-mono text-ink-tertiary border border-dashed border-line-em rounded px-1.5 py-0.5">
                    taslak
                  </span>
                )}
              </div>
              <p class="text-sm text-ink-secondary mt-1">{post.data.description}</p>
              <div class="flex items-center gap-3 mt-2">
                <span class="text-xs font-mono text-ink-tertiary">
                  {fmtDate(post.data.pubDate)}
                </span>
                {post.data.readingTime && (
                  <span class="text-xs font-mono text-ink-tertiary">
                    · {post.data.readingTime}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-ink-secondary text-sm mt-8">henüz yazı yok — yakında burada olacak.</p>
      )}
    </div>
  </section>
</Layout>
