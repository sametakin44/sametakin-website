---
import Layout from '../components/layout/Layout.astro';
import { getLatestVideos } from '../lib/youtube';

const videos = await getLatestVideos('UC-4rif4ktwvlvEflz-frkIw', 20);

function fmtDate(d: string) {
  try {
    return new Intl.DateTimeFormat('tr-TR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(new Date(d));
  } catch {
    return d;
  }
}
---

<Layout
  title="videolar — samet akın"
  description="samet akın'ın youtube'daki teknik videoları"
>
  <section class="mx-auto max-w-[1200px] px-5 py-24">
    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-4 mb-12">
      <div>
        <h1 class="text-4xl font-bold tracking-tight">videolar</h1>
        <p class="text-ink-400 mt-2 text-sm">derin öğrenme, llm ve yapay zeka üzerine türkçe içerikler</p>
      </div>
      <a
        href="https://youtube.com/@sametakin44"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-accent text-white px-4 py-2 rounded-md text-sm font-mono hover:bg-accent-hover transition-colors duration-200"
      >
        @sametakin44 · youtube'da takip et →
      </a>
    </div>

    {videos.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {videos.map((v) => (
          <a
            href={v.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-xl border border-ink-800 bg-ink-900/40 overflow-hidden hover:border-accent/40 transition-all duration-200"
          >
            <div class="aspect-video overflow-hidden bg-ink-800">
              {v.thumbnail && (
                <img
                  src={v.thumbnail}
                  alt={v.title}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-200"
                  loading="lazy"
                />
              )}
            </div>
            <div class="p-4">
              <h3 class="text-sm text-ink-100 group-hover:text-accent transition-colors duration-200 line-clamp-2 leading-snug">
                {v.title}
              </h3>
              <p class="text-xs font-mono text-ink-400 mt-2">
                {fmtDate(v.published)}
              </p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-sm text-ink-400">videolar yüklenemedi.</p>
    )}
  </section>
</Layout>
