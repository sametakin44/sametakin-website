---
import Layout from '../components/layout/Layout.astro';

const channels = [
  {
    label: 'email',
    value: 'sametakin44@gmail.com',
    href: 'mailto:sametakin44@gmail.com',
    muted: false,
  },
  {
    label: 'linkedin',
    value: '/in/sametakin44',
    href: 'https://linkedin.com/in/sametakin44',
    muted: false,
  },
  {
    label: 'youtube',
    value: '@sametakin44',
    href: 'https://youtube.com/@sametakin44',
    muted: false,
  },
  {
    label: 'github',
    value: '(coming soon)',
    href: '#',
    muted: true,
  },
];
---

<Layout
  title="Contact — Samet Akın"
  description="Reach Samet Akın by email, LinkedIn, or YouTube."
>
  <section class="mx-auto max-w-4xl px-5 py-24">
    <header class="mb-12">
      <p class="text-xs font-mono text-ink-tertiary uppercase tracking-wider mb-2">
        contact
      </p>
      <h1 class="text-3xl md:text-4xl font-semibold text-ink-primary">
        get in touch
      </h1>
      <p class="text-sm text-ink-secondary mt-3 max-w-md">
        Collaboration, research, a talk about a model — drop a line.
      </p>
    </header>

    <ul class="divide-y divide-line-hair border-y border-line-hair max-w-xl font-mono text-sm">
      {channels.map((c) => (
        <li class="flex justify-between py-4 px-2 -mx-2 hover:bg-bg-surface transition">
          <span class="text-ink-tertiary uppercase tracking-wider">{c.label}</span>
          <a
            href={c.href}
            target={c.href.startsWith('http') ? '_blank' : undefined}
            rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class:list={[
              c.muted ? 'text-ink-tertiary' : 'text-ink-primary hover:text-accent',
            ]}
          >
            {c.value}{!c.muted && ' →'}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
