---
import Layout from '../components/layout/Layout.astro';

const channels = [
  {
    label: 'email',
    value: 'sametakin44@gmail.com',
    href: 'mailto:sametakin44@gmail.com',
    muted: false,
  },
  {
    label: 'linkedin',
    value: '/in/sametakin44',
    href: 'https://linkedin.com/in/sametakin44',
    muted: false,
  },
  {
    label: 'youtube',
    value: '@sametakin44',
    href: 'https://youtube.com/@sametakin44',
    muted: false,
  },
  {
    label: 'github',
    value: '/sametakin44',
    href: 'https://github.com/sametakin44',
    muted: false,
  },
];
---

<Layout
  title="Contact — Samet Akın"
  description="Reach Samet Akın by email, LinkedIn, or YouTube."
>
  <section class="mx-auto max-w-4xl px-5 py-24">
    <header class="mb-14">
      <p class="eyebrow mb-3">Contact</p>
      <h1 class="font-display text-3xl md:text-5xl text-ink-primary">
        Get in touch
      </h1>
      <p class="text-[15px] text-ink-secondary mt-4 max-w-md leading-[1.7]">
        Collaboration, research, a talk about a model — drop a line.
      </p>
    </header>

    <ul class="divide-y divide-line-hair border-y border-line-hair max-w-xl font-mono text-sm">
      {channels.map((c) => (
        <li class="flex justify-between items-baseline py-5 px-2 -mx-2 hover:bg-bg-surface transition-colors duration-[400ms]">
          <span class="eyebrow">{c.label}</span>
          <a
            href={c.href}
            target={c.href.startsWith('http') ? '_blank' : undefined}
            rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class:list={[
              c.muted
                ? 'text-ink-tertiary'
                : 'text-ink-primary hover:text-accent transition-colors duration-300',
            ]}
          >
            {c.value}{!c.muted && ' →'}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
