---
import Layout from '../../components/layout/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}
---

<Layout
  title={`${post.data.title} — Samet Akın`}
  description={post.data.description}
>
  <article class="mx-auto max-w-2xl px-5 py-24">
    <a
      href="/writing"
      class="font-mono text-[11px] uppercase tracking-[0.25em] text-ink-tertiary hover:text-accent transition-colors duration-300"
    >
      ← All writing
    </a>

    <header class="mt-10 mb-14">
      <div class="flex items-baseline gap-3">
        {post.data.draft && (
          <span class="eyebrow border border-dashed border-line-sub rounded-[2px] px-1.5 py-0.5">
            Draft
          </span>
        )}
        {post.data.readingTime && (
          <span class="font-mono text-xs text-ink-tertiary">{post.data.readingTime}</span>
        )}
      </div>
      <h1 class="font-display text-4xl md:text-5xl leading-[1.05] mt-4 text-ink-primary">
        {post.data.title}
      </h1>
      <p class="text-ink-secondary mt-3 text-[15px] leading-[1.7]">{post.data.description}</p>
      <time class="block font-mono text-xs text-ink-tertiary mt-5">
        {fmtDate(post.data.pubDate)}
      </time>
    </header>

    <div class="prose dark:prose-invert prose-lg max-w-none prose-headings:font-display prose-headings:font-medium prose-a:text-accent prose-code:font-mono prose-code:text-sm prose-pre:bg-bg-surface prose-pre:border prose-pre:border-line-hair prose-pre:rounded-[2px]">
      <Content />
    </div>
  </article>
</Layout>
