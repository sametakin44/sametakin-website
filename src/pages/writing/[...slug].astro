---
import Layout from '../../components/layout/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}
---

<Layout
  title={`${post.data.title} — Samet Akın`}
  description={post.data.description}
>
  <article class="mx-auto max-w-2xl px-5 py-24">
    <a
      href="/writing"
      class="text-xs font-mono text-ink-tertiary hover:text-accent transition-colors duration-200"
    >
      ← all writing
    </a>

    <header class="mt-8 mb-12">
      <div class="flex items-center gap-3">
        {post.data.draft && (
          <span class="text-[10px] font-mono text-ink-tertiary border border-dashed border-line-em rounded px-1.5 py-0.5">
            draft
          </span>
        )}
        {post.data.readingTime && (
          <span class="text-xs font-mono text-ink-tertiary">{post.data.readingTime}</span>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mt-3 text-ink-primary">
        {post.data.title}
      </h1>
      <p class="text-ink-secondary mt-2 text-sm">{post.data.description}</p>
      <time class="block text-xs font-mono text-ink-tertiary mt-4">
        {fmtDate(post.data.pubDate)}
      </time>
    </header>

    <div class="prose prose-invert prose-lg max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-accent prose-code:font-mono prose-code:text-sm prose-pre:bg-bg-surface prose-pre:border prose-pre:border-line-sub">
      <Content />
    </div>
  </article>
</Layout>
