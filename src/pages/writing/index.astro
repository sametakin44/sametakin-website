---
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}
---

<Layout
  title="Writing — Samet Akın"
  description="Technical notes on RAG, LLMs, and agentic AI."
>
  <section class="mx-auto max-w-[1200px] px-5 py-24">
    <p class="text-xs font-mono text-ink-tertiary uppercase tracking-wider mb-2">
      writing
    </p>
    <h1 class="text-3xl md:text-4xl font-semibold text-ink-primary">notes</h1>
    <p class="text-ink-secondary mt-2 text-sm">technical notes, experiments, lessons learned</p>

    <div id="draft" class="mt-12">
      {posts.length > 0 ? (
        <div class="divide-y divide-line-sub">
          {posts.map((post) => (
            <a
              href={`/writing/${post.id}`}
              class="group block py-5 hover:bg-bg-surface/60 -mx-4 px-4 rounded-lg transition-colors duration-200"
            >
              <div class="flex items-center gap-3">
                <h2 class="text-ink-primary font-medium group-hover:text-accent transition-colors duration-200">
                  {post.data.title}
                </h2>
                {post.data.draft && (
                  <span class="text-[10px] font-mono text-ink-tertiary border border-dashed border-line-em rounded px-1.5 py-0.5">
                    draft
                  </span>
                )}
              </div>
              <p class="text-sm text-ink-secondary mt-1">{post.data.description}</p>
              <div class="flex items-center gap-3 mt-2">
                <span class="text-xs font-mono text-ink-tertiary">
                  {fmtDate(post.data.pubDate)}
                </span>
                {post.data.readingTime && (
                  <span class="text-xs font-mono text-ink-tertiary">
                    · {post.data.readingTime}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-ink-secondary text-sm mt-8">nothing published yet — coming soon.</p>
      )}
    </div>
  </section>
</Layout>
