---
import Layout from '../../components/layout/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function fmtDate(d: Date) {
  return new Intl.DateTimeFormat('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}
---

<Layout
  title="Writing — Samet Akın"
  description="Technical notes on RAG, LLMs, and agentic AI."
>
  <section class="mx-auto max-w-[1200px] px-5 py-24">
    <p class="eyebrow mb-3">Writing</p>
    <h1 class="font-display text-3xl md:text-5xl text-ink-primary">Notes</h1>
    <p class="text-[15px] text-ink-secondary mt-4 leading-[1.7]">technical notes, experiments, lessons learned</p>

    <div id="draft" class="mt-14">
      {posts.length > 0 ? (
        <div>
          {posts.map((post) => (
            <a
              href={`/writing/${post.id}`}
              class="group grid md:grid-cols-[140px_1fr_auto] gap-6 items-baseline border-t border-line-hair last:border-b py-8 md:py-10 px-2 -mx-2 hover:bg-bg-surface transition-colors duration-[400ms]"
            >
              <span class="font-mono text-xs text-ink-tertiary whitespace-nowrap">
                {fmtDate(post.data.pubDate)}
              </span>
              <div>
                <div class="flex items-baseline gap-3">
                  <h2 class="font-display text-2xl md:text-3xl text-ink-primary group-hover:text-accent transition-colors duration-300">
                    {post.data.title}
                  </h2>
                  {post.data.draft && (
                    <span class="eyebrow border border-dashed border-line-sub rounded-[2px] px-1.5 py-0.5 shrink-0">
                      Draft
                    </span>
                  )}
                </div>
                <p class="text-sm text-ink-secondary max-w-xl mt-2 leading-[1.7]">{post.data.description}</p>
                {post.data.readingTime && (
                  <p class="font-mono text-xs text-ink-tertiary mt-3">
                    {post.data.readingTime}
                  </p>
                )}
              </div>
              <span
                aria-hidden
                class="hidden md:block font-mono text-ink-tertiary group-hover:text-accent group-hover:translate-x-1.5 transition-all duration-300"
              >
                →
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-ink-secondary text-sm mt-8">nothing published yet — coming soon.</p>
      )}
    </div>
  </section>
</Layout>
