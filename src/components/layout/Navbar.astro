---
const links = [
  { href: '/#works', label: 'çalışmalar' },
  { href: '/#videos', label: 'videolar' },
  { href: '/blog', label: 'yazılar' },
  { href: '/cv', label: 'cv' },
  { href: '/#contact', label: 'iletişim' },
];
---

<nav class="w-full border-b border-ink-800">
  <div class="mx-auto max-w-[1200px] px-5 flex items-center justify-between h-14">
    <a href="/" class="font-mono text-sm tracking-tight text-ink-100">
      samet akın<span class="text-accent mx-1">•</span>
    </a>
    <ul class="flex items-center gap-6">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-ink-400 hover:text-ink-100 transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
