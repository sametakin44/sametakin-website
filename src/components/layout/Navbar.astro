---
import ThemeToggle from '../ui/ThemeToggle.tsx';
import MobileMenu from '../ui/MobileMenu.tsx';

const links = [
  { href: '/#work', label: 'work' },
  { href: '/videos', label: 'videos' },
  { href: '/writing', label: 'writing' },
  { href: '/experience', label: 'experience' },
  { href: '/contact', label: 'contact' },
];
---

<nav
  id="site-nav"
  class="sticky top-0 z-50 w-full backdrop-blur-sm border-b border-line-hair"
  style="background-color: var(--bg-glass)"
>
  <div class="mx-auto max-w-[1200px] px-5 flex items-center justify-between h-14">
    {/* Logo */}
    <a
      href="/"
      class="flex items-center gap-2 font-display text-lg text-ink-primary hover:text-accent transition-colors duration-300"
    >
      Samet <span class="italic">Akın</span>
    </a>

    {/* Desktop links */}
    <div class="hidden md:flex items-center gap-7">
      <ul class="flex items-center gap-7">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-mono text-[11px] uppercase tracking-[0.25em] text-ink-secondary hover:text-accent transition-colors duration-300 relative after:content-[''] after:absolute after:left-0 after:-bottom-1 after:h-px after:w-0 after:bg-warm hover:after:w-full after:transition-all after:duration-300"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle client:load />
    </div>

    {/* Mobile */}
    <div class="flex items-center gap-3 md:hidden">
      <ThemeToggle client:load />
      <MobileMenu client:load />
    </div>
  </div>
</nav>

<script>
  // Aşağı inerken gizlen, yukarı çıkınca görün (Lenis native scroll'u sürdüğü
  // için window scroll event'i her sayfada çalışır).
  const nav = document.getElementById('site-nav');
  let last = 0;
  window.addEventListener(
    'scroll',
    () => {
      const y = window.scrollY;
      nav?.classList.toggle('nav-hidden', y > last && y > 80);
      last = y;
    },
    { passive: true },
  );
</script>
