---
import ThemeToggle from '../ui/ThemeToggle.tsx';
import MobileMenu from '../ui/MobileMenu.tsx';

const links = [
  { href: '/#work', label: 'work' },
  { href: '/videos', label: 'videos' },
  { href: '/writing', label: 'writing' },
  { href: '/experience', label: 'experience' },
  { href: '/contact', label: 'contact' },
];
---

<nav
  class="sticky top-0 z-50 w-full backdrop-blur-md border-b border-line-hair"
  style="background-color: var(--bg-glass)"
>
  <div class="mx-auto max-w-[1200px] px-5 flex items-center justify-between h-14">
    {/* Logo */}
    <a
      href="/"
      class="flex items-center gap-2 font-mono text-sm text-ink-primary hover:text-accent transition"
    >
      Samet Akın
    </a>

    {/* Desktop links */}
    <div class="hidden md:flex items-center gap-6">
      <ul class="flex items-center gap-6">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-mono lowercase text-ink-secondary hover:text-accent transition-colors duration-200 relative after:content-[''] after:absolute after:left-0 after:-bottom-0.5 after:h-px after:w-0 after:bg-accent hover:after:w-full after:transition-all after:duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle client:load />
    </div>

    {/* Mobile */}
    <div class="flex items-center gap-3 md:hidden">
      <ThemeToggle client:load />
      <MobileMenu client:load />
    </div>
  </div>
</nav>
