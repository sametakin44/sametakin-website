---
const socials = [
  {
    href: 'https://github.com/sametakin44',
    label: 'GitHub',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
  {
    href: 'https://linkedin.com/in/sametakin44',
    label: 'LinkedIn',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    href: 'https://youtube.com/@sametakin44',
    label: 'YouTube',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>`,
  },
  {
    href: 'mailto:sametakin44@gmail.com',
    label: 'Email',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
];
---

<footer class="mt-24 border-t border-line-hair py-10">
  <div class="mx-auto max-w-[1200px] px-5 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
    {/* Left */}
    <span class="text-ink-secondary">&copy; 2026 Samet Akın</span>

    {/* Middle */}
    <span class="text-ink-tertiary text-xs">
      building things <span class="opacity-60 ml-0.5">&#x1F989;</span>
    </span>

    {/* Sağ — sosyal ikonlar */}
    <div class="flex items-center gap-4">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          class="text-ink-secondary hover:text-accent transition-colors duration-200"
        >
          <Fragment set:html={s.icon} />
        </a>
      ))}
    </div>
  </div>
</footer>
