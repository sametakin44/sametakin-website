---
import '../../styles/global.css';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hideFooter?: boolean;
}

const {
  title = 'Samet Akın — AI Engineer & Researcher',
  description = 'AI engineer and researcher working on deep learning, large language models, and agentic systems.',
  hideFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05070B" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- <meta property="og:image" content="/assets/og/default.png" /> uncomment once the image exists -->

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Prevent flash: apply saved theme before paint -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'light') {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    {!hideFooter && <Footer />}
  </body>
</html>
