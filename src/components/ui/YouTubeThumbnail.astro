---
interface Props {
  videoId: string;
  title: string;
  className?: string;
}

const { videoId, title, className = '' } = Astro.props;
const src = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const fallback = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
---

<img
  src={src}
  alt={title}
  loading="lazy"
  class={`w-full h-full object-cover ${className}`}
  onerror={`this.onerror=null; this.src='${fallback}';`}
/>
