---
const drafts = [
  {
    title: 'Chunking strategies in RAG: fixed, semantic, and late',
    desc: 'How splitting the same document three different ways affects retrieval quality.',
    reading: '~8 min read',
    href: '/writing#draft',
  },
  {
    title: 'Multi-query generation for agentic systems',
    desc: "How we diversify a ReAct agent's queries, and what it does to the final answer.",
    reading: '~10 min read',
    href: '/writing#draft',
  },
];
---

<section id="writing" class="mx-auto max-w-[1200px] px-5 mt-24">
  <div class="mb-8">
    <h2 class="font-mono text-sm text-ink-secondary lowercase">writing</h2>
    <p class="text-sm text-ink-tertiary mt-1">a few notes, coming soon</p>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    {drafts.map((d) => (
      <a
        href={d.href}
        class="group rounded-xl border border-dashed border-line-em bg-bg-surface/60 p-6 hover:border-accent/40 transition-all duration-200"
      >
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[10px] font-mono text-ink-tertiary border border-line-sub rounded px-1.5 py-0.5">
            draft
          </span>
          <span class="text-[10px] font-mono text-ink-tertiary">{d.reading}</span>
        </div>
        <h3 class="text-sm text-ink-primary group-hover:text-accent transition-colors duration-200 leading-snug">
          {d.title}
        </h3>
        <p class="text-xs text-ink-secondary mt-2 leading-relaxed">{d.desc}</p>
      </a>
    ))}
  </div>
</section>
