---
import type { YouTubeVideo } from '../../lib/youtube';

interface Props {
  videos: YouTubeVideo[];
}

const { videos } = Astro.props;

function fmtDate(d: string) {
  try {
    return new Intl.DateTimeFormat('en-US', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(new Date(d));
  } catch {
    return d;
  }
}
---

<section id="videos" class="mx-auto max-w-[1200px] px-5 mt-24">
  <div class="flex items-baseline justify-between mb-8">
    <h2 class="font-mono text-sm text-ink-secondary lowercase">latest videos</h2>
    <a
      href="/videos"
      class="text-xs font-mono text-ink-tertiary hover:text-accent transition-colors duration-200"
    >
      see all →
    </a>
  </div>

  {videos.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {videos.map((v) => (
        <a
          href={v.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-xl border border-line-sub bg-bg-surface overflow-hidden hover:border-accent/40 transition-all duration-200"
        >
          <div class="aspect-video overflow-hidden bg-bg-elevated">
            {v.thumbnail && (
              <img
                src={v.thumbnail}
                alt={v.title}
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-200"
                loading="lazy"
              />
            )}
          </div>
          <div class="p-4">
            <h3 class="text-sm text-ink-primary group-hover:text-accent transition-colors duration-200 line-clamp-2 leading-snug">
              {v.title}
            </h3>
            <p class="text-xs font-mono text-ink-tertiary mt-2">
              {fmtDate(v.published)}
            </p>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <p class="text-sm text-ink-secondary">videos failed to load.</p>
  )}
</section>
