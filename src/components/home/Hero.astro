---
import HeroObject from './HeroObject.tsx';
import { bio, techStack } from '../../data/bio';

type Tone = 'default' | 'accent' | 'warm' | 'mint';

const techPills: { label: string; tone: Tone }[] = [
  { label: 'PyTorch', tone: 'default' },
  { label: 'LangChain', tone: 'accent' },
  { label: 'RAG', tone: 'default' },
  { label: 'Transformers', tone: 'warm' },
  { label: 'LangGraph', tone: 'default' },
  { label: 'FastAPI', tone: 'mint' },
  { label: 'Qdrant', tone: 'default' },
  { label: 'Python', tone: 'default' },
];

const fallbackPills: { label: string; tone: Tone }[] = techStack.map((t) => ({
  label: t,
  tone: 'default',
}));

const pills = techPills.length ? techPills : fallbackPills;

const pillBase =
  'rounded-full px-3 py-1 text-xs font-mono transition-colors duration-200 cursor-default border';

const pillToneClass: Record<Tone, string> = {
  default:
    'border-line-sub text-ink-secondary hover:border-line-em hover:text-ink-primary',
  accent:
    'border-accent/40 text-accent hover:border-accent hover:text-accent',
  warm: 'border-warm/40 text-warm hover:border-warm hover:text-warm',
  mint: 'border-mint/40 text-mint hover:border-mint hover:text-mint',
};

const bioParagraphs = bio.split('\n\n').map((p) =>
  p.replace(
    "youtube'da türkçe anlatıyorum",
    '<span class="text-warm font-medium">youtube\'da türkçe anlatıyorum</span>',
  ),
);
---

<section class="relative isolate overflow-hidden">
  <div
    aria-hidden
    class="absolute inset-0 -z-10 opacity-70 dark:opacity-40 pointer-events-none"
    style="background: radial-gradient(ellipse at top, color-mix(in srgb, var(--accent-muted) 14%, transparent), transparent 62%);"
  ></div>

  <div class="mx-auto max-w-6xl px-5 py-20 md:py-28">
    <div class="grid md:grid-cols-[1.25fr_1fr] gap-10 lg:gap-16 items-center">
      {/* ── Sol sütun ── */}
      <div>
        {/* Durum */}
        <div class="inline-flex items-center gap-2 text-xs font-mono mb-6">
          <span class="h-1.5 w-1.5 rounded-full bg-status animate-pulse"></span>
          <span class="text-ink-secondary">yeni fırsatlara açık</span>
        </div>

        {/* Başlık */}
        <h1
          class="text-[56px] leading-[0.95] md:text-[78px] md:leading-[0.92] font-semibold tracking-[-0.035em] text-ink-primary lowercase"
        >
          samet <span class="text-accent">akın</span><span class="text-warm">.</span>
        </h1>

        {/* Alt başlık */}
        <p class="text-sm md:text-base font-mono text-ink-tertiary mt-3">
          ai engineer · researcher · istanbul
        </p>

        {/* Bio */}
        <div class="mt-6 space-y-4 text-ink-secondary leading-relaxed text-[15px] max-w-md">
          {bioParagraphs.map((p) => (
            <p set:html={p}></p>
          ))}
        </div>

        {/* Tech pills */}
        <div class="flex flex-wrap gap-2 mt-6">
          {pills.map((t) => (
            <span class={`${pillBase} ${pillToneClass[t.tone]}`}>{t.label}</span>
          ))}
        </div>

        {/* CTA */}
        <div class="flex gap-3 mt-8">
          <a
            href="#calismalar"
            class="bg-accent text-white px-5 py-2.5 rounded-md text-sm font-medium hover:bg-accent-hover hover:-translate-y-px transition-all duration-200"
          >
            çalışmalarıma bak
          </a>
          <a
            href="/iletisim"
            class="text-ink-primary border border-line-em px-5 py-2.5 rounded-md text-sm font-medium hover:border-accent hover:text-accent transition-all duration-200"
          >
            iletişim
          </a>
        </div>
      </div>

      {/* ── Sağ sütun: 3D ── */}
      <div class="md:pl-6">
        <HeroObject client:load />
      </div>
    </div>
  </div>
</section>
