---
import HeroObject from './HeroObject.tsx';
---

<section class="relative isolate overflow-hidden min-h-[90vh] flex items-center">
  <div class="mx-auto w-full max-w-6xl px-5 py-20 md:py-28">
    <div class="grid md:grid-cols-[1.25fr_1fr] gap-10 lg:gap-16 items-center">
      {/* ── Left column ── */}
      <div>
        <p class="eyebrow reveal reveal-1">
          AI Engineer · Researcher · Content Producer
        </p>

        <h1
          class="reveal reveal-2 font-display font-medium text-[64px] md:text-[96px] tracking-[-0.01em] leading-[0.95] text-ink-primary mt-5"
        >
          Samet <span class="italic text-accent">Akın</span>
        </h1>

        <div class="reveal reveal-3 mt-8 space-y-3 text-ink-secondary leading-[1.7] text-[15px] md:text-base max-w-md">
          <p>
            I am AI engineer and researcher.
            I like designing systems and pipelines.
          </p>
          <p>
            In my free time, I turn what I learn into Turkish tutorials on
            <a
              href="https://www.youtube.com/@sametakin44"
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-primary border-b border-warm pb-px hover:text-accent transition-colors duration-300"
            >YouTube</a>.
          </p>
        </div>

        <div class="reveal reveal-4 mt-12">
          <a
            href="#work"
            class="font-mono text-[11px] uppercase tracking-[0.25em] text-ink-primary border-b border-accent pb-1 hover:text-accent transition-colors duration-300"
          >
            View selected work
          </a>
        </div>
      </div>

      {/* ── Right column: 3D ── */}
      <div class="md:pl-6 reveal reveal-3">
        <HeroObject client:load />
      </div>
    </div>
  </div>
</section>
