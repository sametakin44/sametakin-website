---
import HeroObject from './HeroObject.tsx';
---

<section class="relative isolate overflow-hidden">
  <div
    aria-hidden
    class="absolute inset-0 -z-10 opacity-70 dark:opacity-40 pointer-events-none"
    style="background: radial-gradient(ellipse at top, color-mix(in srgb, var(--accent-muted) 14%, transparent), transparent 62%);"
  ></div>

  <div class="mx-auto max-w-6xl px-5 py-20 md:py-28">
    <div class="grid md:grid-cols-[1.25fr_1fr] gap-10 lg:gap-16 items-center">
      {/* ── Left column ── */}
      <div>
        <h1
          class="text-[56px] leading-[0.95] md:text-[78px] md:leading-[0.92] font-semibold tracking-[-0.035em] text-ink-primary"
        >
          Samet <span class="text-accent">Akın</span>
        </h1>

        <p class="text-sm md:text-base font-mono text-ink-tertiary mt-3">
          ai engineer · researcher · content producer
        </p>

        <div class="mt-6 space-y-3 text-ink-secondary leading-relaxed text-[15px] max-w-md">
          <p>
            AI engineer and researcher working on deep learning, large language
            models, and agentic systems. I like designing pipelines that reduce
            hallucination and deliver data where it belongs.
          </p>
          <p>
            I'm a computer science undergraduate researcher working on ABR
            signal analysis.
          </p>
          <p>
            In my free time, I turn what I learn into Turkish tutorials on
            <a
              href="https://www.youtube.com/@sametakin44"
              target="_blank"
              rel="noopener noreferrer"
              class="text-warm font-medium hover:underline underline-offset-4"
            >YouTube</a>.
          </p>
        </div>

        <div class="mt-8">
          <a
            href="#work"
            class="inline-block bg-accent text-white px-5 py-2.5 rounded-md text-sm font-medium hover:bg-accent-hover hover:-translate-y-px transition-all duration-200"
          >
            see my work
          </a>
        </div>
      </div>

      {/* ── Right column: 3D ── */}
      <div class="md:pl-6">
        <HeroObject client:load />
      </div>
    </div>
  </div>
</section>
