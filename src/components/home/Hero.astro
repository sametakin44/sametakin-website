---
import NowPanel from './NowPanel.tsx';
import { bio, techStack } from '../../data/bio';
import type { YouTubeVideo } from '../../lib/youtube';

interface Props {
  videos: YouTubeVideo[];
}

const { videos } = Astro.props;

const bioLines = bio.split('\n\n');
---

<section class="mx-auto max-w-[1200px] px-5 py-24">
  <div class="grid lg:grid-cols-[1.1fr_1fr] gap-16 items-start">
    {/* ── Sol sütun ── */}
    <div>
      {/* Müsait rozeti */}
      <div class="inline-flex items-center gap-2 text-xs font-mono">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="text-ink-300">yeni fırsatlara açık</span>
      </div>

      {/* Başlık */}
      <h1 class="text-6xl md:text-7xl tracking-tight font-bold mt-6">
        samet <span class="text-accent">akın</span>
      </h1>

      {/* Alt başlık */}
      <p class="text-ink-400 mt-3 font-mono text-sm">
        ai engineer · researcher · istanbul
      </p>

      {/* Bio */}
      <div class="mt-8 space-y-4 text-ink-300 leading-relaxed text-[15px]">
        {bioLines.map((p) => (
          <p>{p}</p>
        ))}
      </div>

      {/* Tech pills */}
      <div class="flex flex-wrap gap-2 mt-8">
        {techStack.map((tech) => (
          <span class="rounded-full px-3 py-1 text-xs font-mono border border-ink-700 text-ink-300 hover:border-accent hover:text-accent transition-colors duration-200 cursor-default">
            {tech}
          </span>
        ))}
      </div>

      {/* CTA */}
      <div class="flex gap-3 mt-10">
        <a
          href="#calismalar"
          class="bg-accent text-white px-5 py-2.5 rounded-md text-sm font-medium hover:bg-accent-hover hover:-translate-y-px transition-all duration-200"
        >
          çalışmalarıma bak
        </a>
        <a
          href="#iletisim"
          class="text-ink-100 border border-ink-700 px-5 py-2.5 rounded-md text-sm font-medium hover:border-accent hover:text-accent transition-all duration-200"
        >
          iletişim
        </a>
      </div>
    </div>

    {/* ── Sağ sütun ── */}
    <div class="w-full">
      <NowPanel client:load videos={videos} />
    </div>
  </div>
</section>
