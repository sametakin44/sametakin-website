---
type Tone = 'accent' | 'primary' | 'warm' | 'mint';

const metrics: { value: string; label: string; tone: Tone }[] = [
  { value: '5', label: 'ai stajı/araştırma deneyimi', tone: 'accent' },
  { value: '3.84', label: 'gpa · medipol cs (tam burslu)', tone: 'primary' },
  { value: '2', label: 'youtube teknik serisi (deep learning + llm)', tone: 'warm' },
  { value: '2024→', label: 'tübitak 1001 araştırmacısı', tone: 'mint' },
];

const valueTone: Record<Tone, string> = {
  accent: 'text-accent',
  primary: 'text-ink-primary',
  warm: 'text-warm',
  mint: 'text-mint',
};

const hoverTone: Record<Tone, string> = {
  accent: 'group-hover:text-accent',
  primary: 'group-hover:text-accent',
  warm: 'group-hover:text-warm',
  mint: 'group-hover:text-mint',
};
---

<section class="mx-auto max-w-[1200px] px-5 mt-16">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
    {metrics.map((m) => (
      <div class="group rounded-xl border border-line-sub hover:border-line-em bg-bg-surface p-6 transition-colors duration-200">
        <div class={`text-3xl font-mono font-semibold transition-colors duration-200 ${valueTone[m.tone]} ${hoverTone[m.tone]}`}>
          {m.value}
        </div>
        <div class="text-xs text-ink-tertiary mt-2 lowercase leading-relaxed">
          {m.label}
        </div>
      </div>
    ))}
  </div>
</section>
