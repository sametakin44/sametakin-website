---
import { projects } from '../../data/projects';
---

<section id="work" class="mx-auto max-w-5xl px-5 mt-24">
  <div class="mb-10">
    <p class="text-xs font-mono text-ink-tertiary uppercase tracking-wider mb-2">
      work
    </p>
    <h2 class="text-2xl md:text-3xl font-semibold text-ink-primary">
      things I've built
    </h2>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    {projects.map((p) => (
      <article class="group relative rounded-xl border border-line-sub p-6 hover:border-accent/40 hover:-translate-y-0.5 transition bg-bg-surface">
        <h3 class="text-base md:text-lg font-medium text-ink-primary mb-2 group-hover:text-accent transition">
          {p.title}
        </h3>
        <p class="text-sm text-ink-secondary leading-relaxed">
          {p.summary}
        </p>
      </article>
    ))}
  </div>
</section>
