---
import { projects } from '../../data/projects';

const pad = (n: number) => String(n + 1).padStart(2, '0');
---

<section id="work" class="mx-auto max-w-5xl px-5 mt-32">
  <div class="mb-12">
    <p class="eyebrow mb-3">Work</p>
    <h2 class="font-display text-3xl md:text-5xl text-ink-primary">
      Selected work
    </h2>
  </div>

  <ol>
    {projects.map((p, i) => (
      <li class="border-t border-line-hair last:border-b">
        <article class="group grid md:grid-cols-[80px_1fr_auto] gap-6 items-baseline py-8 md:py-10 px-2 -mx-2 hover:bg-bg-surface transition-colors duration-[400ms]">
          <span class="font-mono text-xs text-ink-tertiary">{pad(i)}</span>
          <div>
            <h3 class="font-display text-2xl md:text-4xl text-ink-primary group-hover:text-accent transition-colors duration-300">
              {p.title}
            </h3>
            <p class="text-sm text-ink-secondary max-w-xl mt-2 leading-[1.7]">
              {p.summary}
            </p>
          </div>
          <span
            aria-hidden
            class="hidden md:block font-mono text-ink-tertiary group-hover:text-accent group-hover:translate-x-1.5 transition-all duration-300"
          >
            →
          </span>
        </article>
      </li>
    ))}
  </ol>
</section>
