---
import { projects } from '../../data/projects';
---

<section id="calismalar" class="mx-auto max-w-[1200px] px-5 mt-24">
  <div class="mb-8">
    <h2 class="font-mono text-sm text-ink-300">seçilmiş çalışmalar</h2>
    <h3 class="text-xl text-ink-100 font-semibold mt-1">son 1-2 yılda dokunduğum şeyler</h3>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    {projects.map((p) => (
      <div class="group rounded-xl border border-ink-800 bg-ink-900/40 p-6 hover:border-accent/40 hover:-translate-y-1 transition-all duration-200">
        <span class="inline-block text-xs font-mono text-accent/80 mb-3">
          {p.tag}
        </span>
        <h3 class="text-ink-100 font-semibold leading-snug">{p.title}</h3>
        <p class="text-sm text-ink-400 mt-2 leading-relaxed">{p.summary}</p>
        <p class="text-xs font-mono text-ink-400/70 mt-4">{p.subtitle}</p>
      </div>
    ))}
  </div>
</section>
