---
import { currently } from '../../data/currently';
---

<div class="border-y border-line-hair py-4">
  <div class="mx-auto max-w-[1200px] px-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-xs md:text-sm font-mono">
    <span class="flex items-center gap-2">
      <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
      <span class="text-ink-tertiary uppercase tracking-wider">currently</span>
    </span>
    <span class="text-ink-tertiary">·</span>
    <span class="text-ink-secondary">
      {currently.prefix}
      <span class="text-ink-primary">{currently.highlight}</span>
      {currently.suffix}
    </span>
  </div>
</div>
