---
import { currently } from '../../data/currently';

const copy = currently.active ? currently.optionA : currently.optionB;
const emphasis = currently.active ? currently.optionAEmphasis : currently.optionBEmphasis;
---

<div class="border-y border-line-hair py-4">
  <div class="mx-auto max-w-[1200px] px-5 flex flex-wrap items-baseline gap-x-3 gap-y-2 font-mono text-xs">
    <span class="flex items-center gap-2">
      <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
      <span class="eyebrow">Now</span>
    </span>
    <span class="text-ink-tertiary">·</span>
    <span class="text-ink-secondary">
      {copy}
      <span class="text-ink-primary">{emphasis}</span>
    </span>
  </div>
</div>
