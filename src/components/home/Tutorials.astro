---
import { tutorialPlaylists } from '../../data/playlists';
import { getPlaylistData } from '../../lib/youtube';
import YouTubeThumbnail from '../ui/YouTubeThumbnail';

const playlists = tutorialPlaylists.map((meta) => ({
  meta,
  data: getPlaylistData(meta.id),
}));
---

<section id="tutorials" class="mx-auto max-w-5xl px-5 mt-32">
  <div class="mb-12">
    <p class="eyebrow mb-3">Tutorials</p>
    <h2 class="font-display text-3xl md:text-5xl text-ink-primary">
      Turkish video series I'm building
    </h2>
    <p class="text-[15px] text-ink-secondary mt-4 max-w-lg leading-[1.7]">
      Two ongoing playlists for people learning AI in Turkish.
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
    {playlists.map(({ meta, data }) => {
      if (!data) return null;
      const count = meta.manualVideoCount ?? data.videoCount;
      const latest = data.latestVideo;
      return (
        <a
          href={data.playlistUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group block"
        >
          <div class="aspect-video relative overflow-hidden rounded-[2px] bg-bg-elevated isolate">
            {latest && (
              <YouTubeThumbnail
                videoId={latest.id}
                title={latest.title}
                className="group-hover:scale-[1.02] transition-transform duration-700 ease-out"
                client:visible
              />
            )}
          </div>

          <div class="pt-5 border-t border-line-hair mt-5">
            <p class="eyebrow mb-3">Series · {count} videos</p>
            <h3 class="font-display text-2xl text-ink-primary group-hover:text-accent transition-colors duration-300">
              {meta.title}
            </h3>
            <p class="text-sm text-ink-secondary leading-[1.7] mt-2">
              {meta.description}
            </p>
            {latest && (
              <div class="mt-5 pt-4 border-t border-line-hair flex items-baseline justify-between gap-3 font-mono text-[11px]">
                <span class="uppercase tracking-[0.25em] text-warm shrink-0">
                  Latest
                </span>
                <span class="text-ink-secondary truncate normal-case">
                  {latest.title}
                </span>
              </div>
            )}
          </div>
        </a>
      );
    })}
  </div>

  <div class="mt-14 flex justify-center">
    <a
      href="https://www.youtube.com/@sametakin44"
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-[11px] uppercase tracking-[0.25em] text-ink-tertiary hover:text-accent transition-colors duration-300 inline-flex items-center gap-2"
    >
      More on YouTube
      <span aria-hidden>→</span>
    </a>
  </div>
</section>
